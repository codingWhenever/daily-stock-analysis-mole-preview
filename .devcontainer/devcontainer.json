{
  "name": "DSA Web Preview",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "DSA Web",
      "onAutoForward": "notify",
      "protocol": "http",
      "visibility": "public"
    }
  },
  "postCreateCommand": "bash scripts/start-codespaces-preview.sh --setup-only",
  "postStartCommand": "bash scripts/start-codespaces-preview.sh --serve-only",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
